S_00000212c9e57710 .scope module, "test_bench3" "test_bench3" 2 1;
 .timescale 0 0;
v00000212c9daaf70_0 .var "a", 0 0;
v00000212c9dab010_0 .var "b", 0 0;
v00000212c9dab0b0_0 .net "behav_out", 0 0, v00000212c9e56950_0;  1 drivers
v00000212c9dab150_0 .net "data_out", 0 0, L_00000212c9e33000;  1 drivers
v00000212c9dab1f0_0 .net "gate_out", 0 0, L_00000212c9e32970;  1 drivers
S_00000212c9e578a0 .scope module, "DUT" "xor_gate" 2 6, 3 1 0, S_00000212c9e57710;
 .timescale 0 0;
    .port_info 0 /INPUT 1 "a";
    .port_info 1 /INPUT 1 "b";
    .port_info 2 /OUTPUT 1 "gate_out";
    .port_info 3 /OUTPUT 1 "data_out";
    .port_info 4 /OUTPUT 1 "behav_out";
L_00000212c9e32970 .functor XOR 1, v00000212c9daaf70_0, v00000212c9dab010_0, C4<0>, C4<0>;
L_00000212c9e33000 .functor XOR 1, v00000212c9daaf70_0, v00000212c9dab010_0, C4<0>, C4<0>;
v00000212c9e32ba0_0 .net "a", 0 0, v00000212c9daaf70_0;  1 drivers
v00000212c9e32dc0_0 .net "b", 0 0, v00000212c9dab010_0;  1 drivers
v00000212c9e56950_0 .var "behav_out", 0 0;
v00000212c9e328d0_0 .net "data_out", 0 0, L_00000212c9e33000;  alias, 1 drivers
v00000212c9daaca0_0 .net "gate_out", 0 0, L_00000212c9e32970;  alias, 1 drivers
E_00000212c9da76a0 .event anyedge, v00000212c9e32ba0_0, v00000212c9e32dc0_0;
    .scope S_00000212c9e578a0;
T_0 ;
    %wait E_00000212c9da76a0;
    %load/vec4 v00000212c9e32ba0_0;
    %load/vec4 v00000212c9e32dc0_0;
    %xor;
    %store/vec4 v00000212c9e56950_0, 0, 1;
    %jmp T_0;
    .thread T_0, $push;
    .scope S_00000212c9e57710;
T_1 ;
    %vpi_call 2 9 "$dumpfile", "wave3.vcd" {0 0 0};
    %vpi_call 2 10 "$dumpvars", 32'sb00000000000000000000000000000000, S_00000212c9e57710 {0 0 0};
    %vpi_call 2 11 "$display", "===== XOR Gate Testbench =====" {0 0 0};
    %vpi_call 2 12 "$monitor", "===== t=%d A = %b, B = %b, Gate Level Output = %b, Dataflow Output = %b, Behavioral Output = %b =====", $time, v00000212c9daaf70_0, v00000212c9dab010_0, v00000212c9dab1f0_0, v00000212c9dab150_0, v00000212c9dab0b0_0 {0 0 0};
    %vpi_call 2 13 "$display", "===== A = 0, B = 0 =====" {0 0 0};
    %pushi/vec4 0, 0, 1;
    %store/vec4 v00000212c9daaf70_0, 0, 1;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v00000212c9dab010_0, 0, 1;
    %delay 10, 0;
    %vpi_call 2 16 "$display", "===== A = 0, B = 1 =====" {0 0 0};
    %pushi/vec4 0, 0, 1;
    %store/vec4 v00000212c9daaf70_0, 0, 1;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v00000212c9dab010_0, 0, 1;
    %delay 10, 0;
    %vpi_call 2 19 "$display", "===== A = 1, B = 0 =====" {0 0 0};
    %pushi/vec4 1, 0, 1;
    %store/vec4 v00000212c9daaf70_0, 0, 1;
    %pushi/vec4 0, 0, 1;
    %store/vec4 v00000212c9dab010_0, 0, 1;
    %delay 10, 0;
    %vpi_call 2 22 "$display", "===== A = 1, B = 1 =====" {0 0 0};
    %pushi/vec4 1, 0, 1;
    %store/vec4 v00000212c9daaf70_0, 0, 1;
    %pushi/vec4 1, 0, 1;
    %store/vec4 v00000212c9dab010_0, 0, 1;
    %delay 1, 0;
    %vpi_call 2 25 "$finish" {0 0 0};
    %end;
    .thread T_1;
