    %vpi_call 2 12 "$monitor", "===== t=%d A = %b, B = %b, Gate Level Output = %b, Dataflow Output = %b, Behavioral Output = %b =====", $time, v0000022a03bfaf70_0, v0000022a03bfb010_0, v0000022a03bfb1f0_0, v0000022a03bfb150_0, v0000022a03bfb0b0_0 {0 0 0};
    %vpi_call 2 13 "$display", "===== A = 0, B = 0 =====" {0 0 0};
