L_0000022a03c12970 .functor AND 1, v0000022a03bfaf70_0, v0000022a03bfb010_0, C4<1>, C4<1>;
L_0000022a03c13000 .functor AND 1, v0000022a03bfaf70_0, v0000022a03bfb010_0, C4<1>, C4<1>;
